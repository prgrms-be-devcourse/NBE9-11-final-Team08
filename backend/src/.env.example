# ─────────────────────────────────────────────────────────────────
# .env.example  →  cp .env.example .env 후 값 채워서 사용
# .env 파일은 절대 git에 커밋하지 마세요 (.gitignore에 추가 필요)
# ─────────────────────────────────────────────────────────────────

# ── MySQL ────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=eighthlayer
MYSQL_USER=appuser
MYSQL_PASSWORD=changeme_app

# ── JWT ──────────────────────────────────────────────────────────
# 최소 32자 이상의 랜덤 문자열 (예: openssl rand -hex 32)
JWT_SECRET=please-change-this-to-a-random-32-char-or-longer-string

JWT_EXPIRATION_MILLIS=3600000
JWT_REFRESH_EXPIRATION_MILLIS=1209600000

IS_COOKIE_SECURE=true
SAME_SITE=Lax

# ── OpenAI ───────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# ── k6 성능 테스트용 JWT 토큰 ────────────────────────────────────
# 앱 실행 후 /api/auth/login 으로 발급받은 토큰을 여기에 입력
# USER  : ROLE_USER 계정 토큰
# ADMIN : ROLE_ADMIN 계정 토큰
# SELLER: ROLE_SELLER 계정 토큰
K6_USER_TOKEN=eyJhbGciOiJIUzI1NiJ9...
K6_ADMIN_TOKEN=eyJhbGciOiJIUzI1NiJ9...
K6_SELLER_TOKEN=eyJhbGciOiJIUzI1NiJ9...
