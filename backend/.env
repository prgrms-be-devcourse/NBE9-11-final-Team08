JWT_SECRET=please-change-this-to-a-random-32-char-or-longer-string

JWT_EXPIRATION_MILLIS=3600000          # 1시간 (ms)
JWT_REFRESH_EXPIRATION_MILLIS=1209600000  # 14일 (ms)

IS_COOKIE_SECURE=false   # HTTPS 환경이면 true, 로컬 HTTP면 false
SAME_SITE=Lax           # Lax | Strict | None

# ── OpenAI ───────────────────────────────────────────────────────
