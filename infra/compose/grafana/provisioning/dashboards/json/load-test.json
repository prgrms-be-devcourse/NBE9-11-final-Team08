    {
      "type": "timeseries",
      "title": "HikariCP 커넥션 (active / idle / pending)",
      "description": "pending > 0 이면 커넥션을 못 받아 대기 중 → DB 병목 신호.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "id": 21,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 15, "lineWidth": 2, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "pending" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }, { "id": "custom.lineWidth", "value": 3 }, { "id": "custom.fillOpacity", "value": 30 } ] },
          { "matcher": { "id": "byName", "options": "active" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } } ] },
          { "matcher": { "id": "byName", "options": "idle" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] },
          { "matcher": { "id": "byName", "options": "max (pool size)" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "text" } }, { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }, { "id": "custom.fillOpacity", "value": 0 } ] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(hikaricp_connections_active{instance=~\"$instance\"})", "legendFormat": "active" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(hikaricp_connections_idle{instance=~\"$instance\"})", "legendFormat": "idle" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(hikaricp_connections_pending{instance=~\"$instance\"})", "legendFormat": "pending" },
        { "refId": "D", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(hikaricp_connections_max{instance=~\"$instance\"})", "legendFormat": "max (pool size)" }
      ]
    },
    {
      "type": "timeseries",
      "title": "커넥션 획득 대기 시간 / 타임아웃",
      "description": "active가 pool max에 도달하면 획득 대기시간이 치솟는다. timeouts/s > 0 이면 풀 고갈.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "id": 22,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never", "axisPlacement": "left" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "timeouts/s" }, "properties": [ { "id": "custom.axisPlacement", "value": "right" }, { "id": "unit", "value": "ops" }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }, { "id": "custom.drawStyle", "value": "bars" }, { "id": "custom.fillOpacity", "value": 60 } ] },
          { "matcher": { "id": "byName", "options": "max acquire" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(hikaricp_connections_acquire_seconds_sum{instance=~\"$instance\"}[$__rate_interval])) / clamp_min(sum(rate(hikaricp_connections_acquire_seconds_count{instance=~\"$instance\"}[$__rate_interval])), 0.0001)", "legendFormat": "avg acquire" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(hikaricp_connections_acquire_seconds_max{instance=~\"$instance\"})", "legendFormat": "max acquire" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(hikaricp_connections_timeout_total{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "timeouts/s" }
      ]
    },
