  "panels": [
    {
      "type": "text",
      "title": "진단 흐름 (위 → 아래로 읽으며 병목을 좁힌다)",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "options": {
        "mode": "markdown",
        "content": "**레이턴시(p95/p99) 급등** → 아래 Row 순서로 원인 격리\n\n| 단서 | 위치 | 결론 |\n|---|---|---|\n| DB **pending 커넥션 > 0** / 획득 대기 ↑ | Row 2 | **DB 병목** |\n| **GC 빈도·시간 ↑**, Heap max 근접 | Row 3 | **메모리 병목** |\n| **CPU ~100%** | Row 4 | **연산 병목** |\n| Tomcat **busy ≈ max** 인데 DB·CPU 정상 | Row 2 | **스레드 풀 포화** |\n| 위 전부 정상 | — | **애플리케이션 로직 병목** |"
      }
    },

    {
      "type": "row",
      "title": "Row 1 — 요청 처리 (병목의 첫 단서)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 1,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "HTTP 처리량 (RPS)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "id": 11,
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "stacking": { "mode": "normal", "group": "A" }, "lineWidth": 1, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "total" }, "properties": [ { "id": "custom.stacking", "value": { "mode": "none" } }, { "id": "custom.fillOpacity", "value": 0 }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "text" } }, { "id": "custom.lineWidth", "value": 2 } ] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (status) (rate(http_server_requests_seconds_count{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "{{status}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(http_server_requests_seconds_count{instance=~\"$instance\"}[$__rate_interval]))", "legendFormat": "total" }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP 레이턴시 p50 / p95 / p99",
      "description": "히스토그램 버킷 기반. 앱에서 percentiles-histogram 활성 + 재기동 후 데이터가 채워집니다.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "id": 12,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 5, "lineWidth": 2, "showPoints": "never" },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p99" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] },
          { "matcher": { "id": "byName", "options": "p95" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } } ] },
          { "matcher": { "id": "byName", "options": "p50" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] }
        ]
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])))", "legendFormat": "p50" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])))", "legendFormat": "p95" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{instance=~\"$instance\"}[$__rate_interval])))", "legendFormat": "p99" }
      ]
    },
    {
      "type": "table",
      "title": "엔드포인트별 에러율 (4xx / 5xx)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "id": 13,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "align": "auto", "cellOptions": { "type": "auto" }, "filterable": true },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 } ] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "RPS" }, "properties": [ { "id": "unit", "value": "reqps" }, { "id": "custom.cellOptions", "value": { "type": "auto" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "text", "value": null } ] } } ] },
          { "matcher": { "id": "byName", "options": "전체 에러%" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-background" } } ] },
          { "matcher": { "id": "byName", "options": "5xx%" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-background" } } ] }
        ]
      },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "전체 에러%", "desc": true } ] },
      "targets": [
        { "refId": "A", "format": "table", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (uri) (rate(http_server_requests_seconds_count{instance=~\"$instance\", outcome=~\"CLIENT_ERROR|SERVER_ERROR\"}[$__rate_interval])) / clamp_min(sum by (uri) (rate(http_server_requests_seconds_count{instance=~\"$instance\"}[$__rate_interval])), 0.0001)" },
        { "refId": "B", "format": "table", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (uri) (rate(http_server_requests_seconds_count{instance=~\"$instance\", outcome=\"SERVER_ERROR\"}[$__rate_interval])) / clamp_min(sum by (uri) (rate(http_server_requests_seconds_count{instance=~\"$instance\"}[$__rate_interval])), 0.0001)" },
        { "refId": "C", "format": "table", "instant": true, "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (uri) (rate(http_server_requests_seconds_count{instance=~\"$instance\"}[$__rate_interval]))" }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": {
          "excludeByName": { "Time": true },
          "indexByName": { "uri": 0, "Value #A": 1, "Value #B": 2, "Value #C": 3 },
          "renameByName": { "uri": "Endpoint", "Value #A": "전체 에러%", "Value #B": "5xx%", "Value #C": "RPS" }
        } }
      ]
    },

    {
      "type": "row",
