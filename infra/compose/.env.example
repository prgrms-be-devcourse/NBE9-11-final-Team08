DB_NAME=team08
DB_USERNAME=team08
DB_PASSWORD=change-me-database-password
MYSQL_ROOT_PASSWORD=change-me-root-password

JWT_SECRET=change-me-to-at-least-32-characters
JWT_EXPIRATION_MILLIS=3600000
JWT_REFRESH_EXPIRATION_MILLIS=1209600000
IS_COOKIE_SECURE=false
SAME_SITE=Lax
COOKIE_DOMAIN=example.com

OPENAI_API_KEY=change-me
OPENAI_MODEL=gpt-4.1-mini

TOSS_PAYMENTS_SECRET_KEY=change-me-toss-payments-secret-key
TOSS_PAYMENTS_WEBHOOK_SECRET=change-me-toss-payments-webhook-secret
NICEPAY_PAYMENTS_CLIENT_KEY=change-me-nicepay-payments-client-key
NICEPAY_PAYMENTS_SECRET_KEY=change-me-nicepay-payments-secret-key

DOMAIN=api.example.com
BACKEND_UPSTREAM=backend-blue:8080
CORS_ALLOWED_ORIGINS=https://example.com
CERTBOT_EMAIL=admin@example.com
BACKEND_IMAGE=ghcr.io/prgrms-be-devcourse/nbe9-11-final-team08
IMAGE_TAG=latest
BLUE_IMAGE_TAG=latest
GREEN_IMAGE_TAG=latest
BLUE_BACKEND_PORT=8081
GREEN_BACKEND_PORT=8082

AWS_ACCESS_KEY_ID=aws_access_key_id
AWS_SECRET_ACCESS_KEY=aws_secret_access_key
AWS_S3_BUCKET_NAME=aws_s3_bucket_name

CLOUDFRONT_DOMAIN=cloudfront-domain
CLOUDFRONT_KEY_PAIR_ID=dummy-id
CLOUDFRONT_PRIVATE_KEY=cloudfront-private-key

# --- Grafana Cloud 모니터링 (compose.monitoring.yaml). 자세한 건 ../monitoring/README.md ---
# Grafana Cloud > Connections > "Prometheus" 의 remote_write 정보에서 복사
GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-XX-prod-REGION.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_USER=000000
GRAFANA_CLOUD_API_KEY=glc_change-me
# mysqld_exporter 전용 DB 계정 (README 의 GRANT 스니펫으로 미리 생성)
MYSQL_EXPORTER_USER=exporter
MYSQL_EXPORTER_PASSWORD=change-me-exporter-password
