    { "type": "timeseries", "title": "Endpoint avg latency (top 8)", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 }, "id": 2, "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 0, "lineWidth": 1, "showPoints": "never" }, "color": { "mode": "palette-classic" } }, "overrides": [] }, "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }, "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "topk(8, sum by (uri) (rate(http_server_requests_seconds_sum{job=\"spring-boot\", uri!=\"/api/studies/{studyId}/feed/stream\"}[$__rate_interval])) / clamp_min(sum by (uri) (rate(http_server_requests_seconds_count{job=\"spring-boot\", uri!=\"/api/studies/{studyId}/feed/stream\"}[$__rate_interval])), 0.0001))", "legendFormat": "{{uri}}" } ] },
    { "type": "timeseries", "title": "Throughput & 5xx", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 }, "id": 3, "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "color": { "mode": "palette-classic" } }, "overrides": [ { "matcher": { "id": "byName", "options": "5xx" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] } ] }, "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }, "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(http_server_requests_seconds_count{job=\"spring-boot\", uri!=\"/api/studies/{studyId}/feed/stream\"}[$__rate_interval]))", "legendFormat": "total" }, { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(http_server_requests_seconds_count{job=\"spring-boot\", outcome=\"SERVER_ERROR\", uri!=\"/api/studies/{studyId}/feed/stream\"}[$__rate_interval]))", "legendFormat": "5xx" } ] },

    { "type": "row", "title": "② JVM   ③ DB pool", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 12 }, "id": 10, "collapsed": false, "panels": [] },
    { "type": "timeseries", "title": "Heap % & GC pause", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 }, "id": 11, "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never", "axisPlacement": "auto" }, "color": { "mode": "palette-classic" } }, "overrides": [ { "matcher": { "id": "byName", "options": "heap %" }, "properties": [ { "id": "unit", "value": "percent" }, { "id": "custom.axisPlacement", "value": "right" } ] }, { "matcher": { "id": "byName", "options": "gc pause/s" }, "properties": [ { "id": "unit", "value": "s" }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] } ] }, "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }, "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(jvm_memory_used_bytes{job=\"spring-boot\", area=\"heap\"}) / clamp_min(sum(jvm_memory_max_bytes{job=\"spring-boot\", area=\"heap\"}), 1) * 100", "legendFormat": "heap %" }, { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(jvm_gc_pause_seconds_sum{job=\"spring-boot\"}[$__rate_interval]))", "legendFormat": "gc pause/s" } ] },
    { "type": "timeseries", "title": "HikariCP — active vs pending", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 }, "id": 12, "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "color": { "mode": "palette-classic" } }, "overrides": [ { "matcher": { "id": "byName", "options": "pending" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }, { "matcher": { "id": "byName", "options": "max" }, "properties": [ { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } } ] } ] }, "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }, "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(hikaricp_connections_active{job=\"spring-boot\"})", "legendFormat": "active" }, { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(hikaricp_connections_pending{job=\"spring-boot\"})", "legendFormat": "pending" }, { "refId": "C", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(hikaricp_connections_max{job=\"spring-boot\"})", "legendFormat": "max" } ] },

    { "type": "row", "title": "④ MySQL   ⑤ Host", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 }, "id": 20, "collapsed": false, "panels": [] },
    { "type": "timeseries", "title": "MySQL threads running & slow queries", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "gridPos": { "h": 8, "w": 8, "x": 0, "y": 22 }, "id": 21, "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "color": { "mode": "palette-classic" } }, "overrides": [ { "matcher": { "id": "byName", "options": "slow/s" }, "properties": [ { "id": "unit", "value": "ops" }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] } ] }, "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }, "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "mysql_global_status_threads_running{job=\"mysql\"}", "legendFormat": "threads running" }, { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(mysql_global_status_slow_queries{job=\"mysql\"}[$__rate_interval])", "legendFormat": "slow/s" } ] },
    { "type": "timeseries", "title": "Redis hit ratio", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "gridPos": { "h": 8, "w": 8, "x": 8, "y": 22 }, "id": 22, "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "color": { "mode": "palette-classic" } }, "overrides": [] }, "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } }, "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "rate(redis_keyspace_hits_total{job=\"redis\"}[$__rate_interval]) / clamp_min(rate(redis_keyspace_hits_total{job=\"redis\"}[$__rate_interval]) + rate(redis_keyspace_misses_total{job=\"redis\"}[$__rate_interval]), 0.0001)", "legendFormat": "hit ratio" } ] },
    { "type": "timeseries", "title": "Host CPU / Mem / Disk %", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "gridPos": { "h": 8, "w": 8, "x": 16, "y": 22 }, "id": 23, "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 5, "lineWidth": 2, "showPoints": "never" }, "color": { "mode": "palette-classic" } }, "overrides": [] }, "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }, "targets": [ { "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "100 - (avg(rate(node_cpu_seconds_total{job=\"node\", mode=\"idle\"}[$__rate_interval])) * 100)", "legendFormat": "cpu" }, { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "(1 - (node_memory_MemAvailable_bytes{job=\"node\"} / node_memory_MemTotal_bytes{job=\"node\"})) * 100", "legendFormat": "mem" }, { "refId": "C", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "(1 - (node_filesystem_avail_bytes{job=\"node\", mountpoint=\"/\", fstype!~\"tmpfs|overlay\"} / node_filesystem_size_bytes{job=\"node\", mountpoint=\"/\", fstype!~\"tmpfs|overlay\"})) * 100", "legendFormat": "disk /" } ] }
  ]
}
